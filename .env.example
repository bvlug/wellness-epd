# -----------------------------------------------------------------------------
# Wellness EPD — environment variables
#
# Copy this file to `.env.local` and fill in real values for local development.
# Real `.env*` files are git-ignored (see .gitignore); never commit secrets.
# -----------------------------------------------------------------------------

# --- Convex -------------------------------------------------------------------
# Public URL of your Convex deployment. Printed by `npx convex dev` on first run
# and stored automatically; it must also be exposed to the Next.js client.
# Example: https://your-deployment-123.convex.cloud
NEXT_PUBLIC_CONVEX_URL=

# --- Clerk (frontend) ---------------------------------------------------------
# From the Clerk dashboard: API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Custom Clerk auth route locations. These point Clerk's redirects (including
# the middleware's protect() redirect) at the in-app sign-in / sign-up pages
# under app/sign-in and app/sign-up. After auth, users land on the home page.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# --- Clerk <-> Convex auth bridge ---------------------------------------------
# The Clerk JWT issuer domain. Create a JWT template named "convex" in the Clerk
# dashboard (JWT Templates) and copy its Issuer URL here. This value is read by
# `convex/auth.config.ts` so Convex can verify Clerk-issued tokens.
# Example: https://your-app-name.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=
